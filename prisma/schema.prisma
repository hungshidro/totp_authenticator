generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: Prisma 7 CLI tools still require url property
// Runtime uses prisma.config.ts and adapter pattern

model TOTPSecret {
  id        String   @id @default(cuid())
  token     String   @unique
  name      String
  issuer    String?
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
