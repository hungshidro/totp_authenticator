generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Note: Prisma 7 does NOT allow url in schema
// - Migration: Use npm run migrate (custom script)
// - Runtime: Uses prisma.config.ts and adapter pattern

model TOTPSecret {
  id        String   @id @default(cuid())
  token     String   @unique
  name      String
  issuer    String?
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
